# ============================================
# PURAWOW — Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=3000
SESSION_SECRET=your-secret-key-here-change-this

# MongoDB
MONGODB_URI=mongodb://localhost:27017/purawow
# OR use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/purawow

# Email (Nodemailer — Gmail)
EMAIL_USER=hello@purawow.in
EMAIL_PASS=your-gmail-app-password
ADMIN_EMAIL=admin@purawow.in

# Stripe Payment
STRIPE_SECRET_KEY=sk_live_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# Razorpay Payment
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend URL (for CORS)
FRONTEND_URL=https://purawow.in
